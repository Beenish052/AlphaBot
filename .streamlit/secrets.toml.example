# Streamlit secrets template
# ----------------------------------------
# DO NOT commit your real secrets.toml file to GitHub.
# This is just a template showing the format.
#
# For LOCAL testing:
#   1. Copy this file to .streamlit/secrets.toml
#   2. Replace the placeholder below with your real Groq API key
#
# For STREAMLIT CLOUD deployment:
#   Paste the same content into:
#   App settings -> Advanced settings -> Secrets

GROQ_API_KEY = "your-groq-api-key-here"
